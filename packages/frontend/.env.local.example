# Copy to `.env.local` and fill in. .env.local is gitignored; this file is
# tracked as the documented schema.

# ─── Primus Developer Hub ──────────────────────────────────────────────
# https://dev.primuslabs.xyz — create a project to get appId/appSecret.
# appId is browser-visible (signs nothing on its own); appSecret signs the
# attestation request and must stay server-side.
NEXT_PUBLIC_PRIMUS_APP_ID=
PRIMUS_APP_SECRET=

# Dev Hub template UUID — required for the browser/extension flow on
# feat/browser-flow. Upload via the developer-template MCP or the Dev Hub UI.
NEXT_PUBLIC_PRIMUS_TEMPLATE_ID=

# ─── On-chain task submission (network-core-sdk) ───────────────────────
# Internal signer the server uses to register the attestation task. NOT a
# user wallet — never surfaced to the browser. Needs Base Sepolia ETH.
PRIMUS_TX_PRIVATE_KEY=
CHAIN_ID=84532
RPC_URL=https://sepolia.base.org

# ─── Local-dev UI prefill (optional) ───────────────────────────────────
# Convenience defaults the form populates with at first paint. Browser-
# visible (NEXT_PUBLIC_*) — only put values here you'd accept being in your
# own JS bundle. Leave any field blank if you want the user to paste it.
# Pull these from DevTools → Application → Cookies → https://www.amazon.com.
NEXT_PUBLIC_AMAZON_ORDER_ID=
NEXT_PUBLIC_AMAZON_SESSION_ID=
NEXT_PUBLIC_AMAZON_UBID_MAIN=
NEXT_PUBLIC_AMAZON_AT_MAIN=
NEXT_PUBLIC_AMAZON_SESS_AT_MAIN=
NEXT_PUBLIC_AMAZON_X_MAIN=
NEXT_PUBLIC_AMAZON_SESSION_TOKEN=
NEXT_PUBLIC_AMAZON_LC_MAIN=
